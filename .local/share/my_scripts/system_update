#!/bin/bash

$AUR_HELPER -Syu
hide_from_menu
apply_mysql_workbench_theme.sh
flatpak update
ya pack -u
npm update -g

if [[ -n $FISH_VERSION ]]; then
	fisher update
elif [[ -n $ZSH_VERSION ]]; then
	zinit update
fi

orphans=$($AUR_HELPER -Qdtq)

if [[ -n "$orphans" ]]; then
	# shellcheck disable=SC2086
	$AUR_HELPER -Rns $orphans
fi

# This script is not responsible for updating Neovim
